# ─────────────────────────────────────────────────────────────────────────────
# AI World Cup 2026 — environment for the OFFLINE pipeline only.
#
#     cp .env.example .env      # then fill in your key (.env is gitignored)
#
# These variables are read ONLY by /pipeline (the offline Monte-Carlo + LLM
# narration that produces app/data.js). They are NEVER bundled into the shipped
# /app — the app reads pre-baked data, makes no live LLM calls, and carries no key.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM narration ─────────────────────────────────  (used by: npm run narrate)
# Provider to narrate with. Implemented: "anthropic" (default) or "gemini".
LLM_PROVIDER=anthropic

# Anthropic / Claude — the default provider. REQUIRED when LLM_PROVIDER=anthropic.
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

#--

# Model id (optional). Default for anthropic: claude-haiku-4-5 (cheap + fast;
# verified against platform.claude.com/docs). Uncomment to override.
# LLM_MODEL=claude-haiku-4-5

# Google Gemini — alternative provider. To use it: set LLM_PROVIDER=gemini above
# and supply a key here. Get one: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-key-here

# ── Monte-Carlo knobs ─────────────────────────────  (used by: npm run simulate)
# Number of tournaments to simulate (optional; default 50000).
# SIMS=50000
# Master RNG seed (optional; default 20260611). Determinism: change it and every
# featured pick and per-nation run changes with it.
# SEED=20260611
