# Offline narration + simulation (pipeline ONLY). These never reach the shipped /app.
# Provider-agnostic; switch with LLM_PROVIDER. Implemented: anthropic (default), gemini.
# (You can also keep these in the repo-root .env — both are loaded.)

LLM_PROVIDER=anthropic

# Anthropic / Claude (default). Key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Model id — verified against platform.claude.com/docs (Haiku 4.5: cheap + fast).
LLM_MODEL=claude-haiku-4-5

# Alternative provider — Google Gemini (set LLM_PROVIDER=gemini): https://aistudio.google.com/apikey
# GEMINI_API_KEY=...

# Monte-Carlo knobs (npm run simulate) — defaults shown.
# SIMS=50000
# SEED=20260611
